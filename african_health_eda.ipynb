    "### 📊 Plot 3: Bar Chart — Average Life Expectancy by Region"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "fig, axes = plt.subplots(1, 2, figsize=(15, 6))\n",
    "\n",
    "# ── Left: Life Expectancy by region ──────────────────────────────────────\n",
    "region_stats = df_clean.groupby('region')['life_expectancy'].agg(['mean','std']).reset_index()\n",
    "region_stats = region_stats.sort_values('mean', ascending=True)\n",
    "\n",
    "colors = ['#E91E63','#FF9800','#9C27B0','#2196F3','#4CAF50']\n",
    "bars = axes[0].barh(region_stats['region'], region_stats['mean'],\n",
    "                    xerr=region_stats['std'], color=colors,\n",
    "                    edgecolor='white', linewidth=1.2,\n",
    "                    error_kw={'capsize':5,'ecolor':'#555555','elinewidth':1.5})\n",
    "\n",
    "for bar, val in zip(bars, region_stats['mean']):\n",
    "    axes[0].text(val + 0.3, bar.get_y() + bar.get_height()/2,\n",
    "                 f'{val:.1f} yrs', va='center', fontsize=10, fontweight='bold')\n",
    "\n",
    "axes[0].set_xlabel('Average Life Expectancy (years)', fontsize=12)\n",
    "axes[0].set_title('Life Expectancy by Region', fontsize=13, fontweight='bold')\n",
    "axes[0].axvline(df_clean['life_expectancy'].mean(), color='red',\n",
    "                linestyle='--', alpha=0.6, label='Africa avg')\n",
    "axes[0].legend(fontsize=9)\n",
    "axes[0].grid(axis='x', alpha=0.3)\n",
    "\n",
    "# ── Right: Electricity access by region ───────────────────────────────────\n",
    "elec_stats = df_clean.groupby('region')['electricity_access_pct'].mean().reset_index()\n",
    "elec_stats = elec_stats.sort_values('electricity_access_pct', ascending=True)\n",
    "\n",
    "bars2 = axes[1].barh(elec_stats['region'], elec_stats['electricity_access_pct'],\n",
    "                     color=colors, edgecolor='white', linewidth=1.2)\n",
    "\n",
    "for bar, val in zip(bars2, elec_stats['electricity_access_pct']):\n",
    "    axes[1].text(val + 0.5, bar.get_y() + bar.get_height()/2,\n",
    "                 f'{val:.1f}%', va='center', fontsize=10, fontweight='bold')\n",
    "\n",
    "axes[1].set_xlabel('Average Electricity Access (%)', fontsize=12)\n",
    "axes[1].set_title('Electricity Access by Region', fontsize=13, fontweight='bold')\n",
    "axes[1].set_xlim(0, 110)\n",
    "axes[1].grid(axis='x', alpha=0.3)\n",
    "\n",
    "fig.suptitle('📊 Regional Comparisons — African Development Indicators 2021',\n",
    "             fontsize=15, fontweight='bold', y=1.02)\n",
    "plt.tight_layout()\n",
    "plt.savefig('plot3_bar_chart_regions.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()"
