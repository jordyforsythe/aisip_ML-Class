    "        'country': list(AFRICAN_COUNTRIES.values()),\n",
    "        'country_code': list(AFRICAN_COUNTRIES.keys()),\n",
    "        'year': [2021] * len(AFRICAN_COUNTRIES),\n",
    "        'region': df_base['region'].tolist(),\n",
    "        # Life expectancy: 50-77 years across Africa (WHO 2021)\n",
    "        'life_expectancy': [\n",
    "            54.3, 64.9, 67.5, 65.5, 72.0, 64.1, 65.5, 63.7, 74.5, 59.3,\n",
    "            58.5, 67.9, 63.9, 61.2, 59.3, 60.1, 67.4, 61.6, 62.4, 64.6,\n",
    "            69.0, 65.5, 61.5, 76.9, 72.9, 76.2, 64.9, 62.1, 54.7, 60.5,\n",
    "            56.1, 62.1, 60.9, 60.5, 54.8, 74.6, 73.4, 69.7, 63.9, 59.4, 53.7\n",
    "        ],\n",
    "        # Under-5 mortality (per 1000 live births, WHO 2021)\n",
    "        'under5_mortality': [\n",
    "            111.2, 33.4, 40.9, 47.5, 20.3, 47.4, 51.7, 44.8, 18.5, 73.7,\n",
    "            79.0, 43.1, 59.2, 55.1, 97.7, 74.4, 80.5, 87.5, 117.9, 37.5,\n",
    "            35.5, 63.0, 72.1, 12.8, 11.4, 13.7, 76.2, 53.5, 108.4, 71.0,\n",
    "            109.5, 88.7, 67.8, 102.4, 84.0, 13.7, 12.8, 29.0, 51.4, 55.0, 74.5\n",
    "        ],\n",
    "        # GDP per capita USD (World Bank 2021)\n",
    "        'gdp_per_capita': [\n",
    "            2085, 7055, 2010, 925, 3561, 2362, 1139, 868, 3352, 1556,\n",
    "            2286, 1596, 1173, 1464, 848, 507, 528, 878, 595, 644,\n",
    "            834, 724, 2037, 4078, 8024, 3809, 748, 800, 490, 627,\n",
    "            595, 1335, 926, 550, 493, 10844, 16387, 7731, 5269, 1036, 1122\n",
    "        ],\n",
    "        # Electricity access %\n",
    "        'electricity_access_pct': [\n",
    "            57.5, 84.2, 75.0, 45.0, 100.0, 83.9, 38.1, 43.4, 100.0, 62.2,\n",
    "            70.0, 69.8, 43.3, 49.7, 52.6, 30.0, 34.1, 18.8, 19.5, 14.0,\n",
    "            46.7, 49.7, 46.2, 99.9, 72.1, 99.9, 46.3, 62.3, 26.1, 29.0,\n",
    "            47.2, 42.0, 43.8, 22.7, 12.5, 99.9, 96.1, 72.7, 56.2, 76.7, 29.4\n",
    "        ],\n",
    "        # Literacy rate %\n",
    "        'literacy_rate_pct': [\n",
    "            62.0, 95.0, 82.0, 51.8, 73.1, 79.0, 80.0, 77.3, 73.8, 77.1,\n",
    "            47.2, 51.9, 87.5, 89.0, 35.5, 63.4, 74.8, 46.0, 35.1, 62.0,\n",
    "            73.2, 61.0, 71.4, 81.4, 91.0, 81.8, 52.1, 58.1, 43.2, 48.3,\n",
    "            47.8, 55.3, 63.7, 37.5, 36.8, 91.3, 96.2, 88.4, 92.3, 88.4, 62.4\n",
    "        ]\n",
    "    }\n",
    "\n",
    "    # Ensure all lists are same length\n",
    "    n = len(synthetic_data['country'])\n",
    "    for k, v in synthetic_data.items():\n",
    "        if len(v) != n:\n",
    "            synthetic_data[k] = v[:n] + [np.nan] * (n - len(v))\n",
    "\n",
    "    df = pd.DataFrame(synthetic_data)\n",
    "    print(f'✅ Fallback dataset ready. Shape: {df.shape}')\n",
    "else:\n",
    "    print('✅ Using live API data.')\n",
    "\n",
    "df.head()"
   ]
