   "source": [
    "## 4️⃣ Data Cleaning"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "print('🧹 Starting Data Cleaning...')\n",
    "df_clean = df.copy()\n",
    "\n",
    "# ── Step 1: Remove duplicates ─────────────────────────────────────────────\n",
    "before = len(df_clean)\n",
    "df_clean.drop_duplicates(subset=['country_code'], keep='first', inplace=True)\n",
    "print(f'  ✅ Removed {before - len(df_clean)} duplicate rows')\n",
    "\n",
    "# ── Step 2: Fix data types ────────────────────────────────────────────────\n",
    "numeric_cols = ['life_expectancy', 'under5_mortality', 'gdp_per_capita',\n",
    "                'electricity_access_pct', 'literacy_rate_pct']\n",
    "for col in numeric_cols:\n",
    "    df_clean[col] = pd.to_numeric(df_clean[col], errors='coerce')\n",
    "df_clean['year'] = df_clean['year'].astype(int)\n",
    "df_clean['country'] = df_clean['country'].str.strip().str.title()\n",
    "df_clean['region'] = df_clean['region'].astype('category')\n",
    "print('  ✅ Data types fixed')\n",
    "\n",
    "# ── Step 3: Handle missing values ─────────────────────────────────────────\n",
    "# Fill numeric NaN with regional median (more accurate than global mean)\n",
    "for col in numeric_cols:\n",
    "    regional_median = df_clean.groupby('region')[col].transform('median')\n",
    "    df_clean[col] = df_clean[col].fillna(regional_median)\n",
    "    # Any still missing (entire region missing) → global median\n",
    "    df_clean[col] = df_clean[col].fillna(df_clean[col].median())\n",
    "print('  ✅ Missing values filled with regional medians')\n",
    "\n",
    "# ── Step 4: Cap outliers using IQR ───────────────────────────────────────\n",
    "for col in numeric_cols:\n",
    "    Q1 = df_clean[col].quantile(0.05)\n",
    "    Q3 = df_clean[col].quantile(0.95)\n",
    "    IQR = Q3 - Q1\n",
    "    lower = Q1 - 1.5 * IQR\n",
    "    upper = Q3 + 1.5 * IQR\n",
    "    df_clean[col] = df_clean[col].clip(lower=max(0, lower), upper=upper)\n",
    "print('  ✅ Outliers capped using IQR method')\n",
    "\n",
    "# ── Step 5: Add income category ───────────────────────────────────────────\n",
    "def classify_income(gdp):\n",
    "    if gdp < 1136:   return 'Low Income'\n",
    "    elif gdp < 4465: return 'Lower-Middle'\n",
    "    elif gdp < 13845:return 'Upper-Middle'\n",
    "    else:             return 'High Income'\n",
    "\n",
    "df_clean['income_group'] = df_clean['gdp_per_capita'].apply(classify_income)\n",
    "print('  ✅ Income group classification added')\n",
    "\n",
    "print(f'\\n✅ Cleaned dataset shape: {df_clean.shape}')\n",
    "print(f'   Remaining nulls: {df_clean.isnull().sum().sum()}')\n",
    "df_clean.head(8)"
   ]
