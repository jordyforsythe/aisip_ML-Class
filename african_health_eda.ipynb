    "## 2️⃣ Download Real African Dataset\n",
    "We use the **World Bank Open Data API** to fetch real African country health and development indicators.  \n",
    "Indicators fetched:\n",
    "- Life expectancy at birth\n",
    "- Under-5 mortality rate\n",
    "- GDP per capita (USD)\n",
    "- Access to electricity (%)\n",
    "- Literacy rate (% adults)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── African country ISO codes ──────────────────────────────────────────────\n",
    "AFRICAN_COUNTRIES = {\n",
    "    'NG': 'Nigeria',      'ZA': 'South Africa',  'KE': 'Kenya',\n",
    "    'ET': 'Ethiopia',     'EG': 'Egypt',          'GH': 'Ghana',\n",
    "    'TZ': 'Tanzania',     'UG': 'Uganda',         'MA': 'Morocco',\n",
    "    'CM': 'Cameroon',     'CI': \"Cote d'Ivoire\",  'SN': 'Senegal',\n",
    "    'ZM': 'Zambia',       'ZW': 'Zimbabwe',       'ML': 'Mali',\n",
    "    'MZ': 'Mozambique',   'MG': 'Madagascar',     'BF': 'Burkina Faso',\n",
    "    'NE': 'Niger',        'MW': 'Malawi',         'RW': 'Rwanda',\n",
    "    'SD': 'Sudan',        'AO': 'Angola',         'DZ': 'Algeria',\n",
    "    'LY': 'Libya',        'TN': 'Tunisia',        'MR': 'Mauritania',\n",
    "    'GM': 'Gambia',       'SL': 'Sierra Leone',   'LR': 'Liberia',\n",
    "    'GN': 'Guinea',       'BJ': 'Benin',          'TG': 'Togo',\n",
    "    'CD': 'DR Congo',     'CF': 'Central African Republic',\n",
    "    'MU': 'Mauritius',    'SC': 'Seychelles',     'BW': 'Botswana',\n",
    "    'NA': 'Namibia',      'SZ': 'Eswatini',       'LS': 'Lesotho'\n",
    "}\n",
    "\n",
    "# ── World Bank indicators ──────────────────────────────────────────────────\n",
    "INDICATORS = {\n",
    "    'SP.DYN.LE00.IN': 'life_expectancy',\n",
    "    'SH.DYN.MORT':    'under5_mortality',\n",
    "    'NY.GDP.PCAP.CD': 'gdp_per_capita',\n",
    "    'EG.ELC.ACCS.ZS': 'electricity_access_pct',\n",
    "    'SE.ADT.LITR.ZS': 'literacy_rate_pct'\n",
    "}\n",
    "\n",
    "def fetch_wb_indicator(indicator, countries, year=2021):\n",
    "    \"\"\"Fetch a World Bank indicator for given countries and year.\"\"\"\n",
    "    iso_str = ';'.join(countries.keys())\n",
    "    url = (f\"https://api.worldbank.org/v2/country/{iso_str}/indicator/{indicator}\"\n",
    "           f\"?date={year}&format=json&per_page=100\")\n",
    "    try:\n",
    "        r = requests.get(url, timeout=15)\n",
    "        data = r.json()\n",
    "        if len(data) < 2:\n",
    "            return {}\n",
    "        return {entry['country']['id']: entry['value']\n",
    "                for entry in data[1] if entry['value'] is not None}\n",
    "    except Exception as e:\n",
    "        print(f'  Warning: Could not fetch {indicator}: {e}')\n",
    "        return {}\n",
    "\n",
    "print('📡 Fetching data from World Bank API...')\n",
    "rows = []\n",
    "for iso, name in AFRICAN_COUNTRIES.items():\n",
    "    row = {'country_code': iso, 'country': name, 'year': 2021,\n",
    "           'region': 'West Africa' if iso in ['NG','GH','SN','ML','NE','BF','CI','TG','BJ','GM','SL','LR','GN','MR'] else\n",
    "                     'East Africa'  if iso in ['KE','ET','TZ','UG','RW','MW','MZ','MG','ZM','SD'] else\n",
    "                     'North Africa' if iso in ['EG','MA','DZ','LY','TN'] else\n",
    "                     'Southern Africa' if iso in ['ZA','ZW','BW','NA','SZ','LS','AO','MU','SC'] else\n",
    "                     'Central Africa'}\n",
    "    rows.append(row)\n",
    "\n",
    "df_base = pd.DataFrame(rows)\n",
    "\n",
    "# Fetch each indicator and merge\n",
    "for indicator_code, col_name in INDICATORS.items():\n",
    "    print(f'  Fetching: {col_name}...')\n",
    "    values = fetch_wb_indicator(indicator_code, AFRICAN_COUNTRIES)\n",
    "    df_base[col_name] = df_base['country_code'].map(values)\n",
    "\n",
    "df = df_base.copy()\n",
    "print(f'\\n✅ Dataset downloaded! Shape: {df.shape}')\n",
    "df.head(10)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "> **Note:** If the API is unavailable (no internet or rate-limited), the cell below generates a realistic synthetic dataset based on actual published WHO/World Bank figures."
