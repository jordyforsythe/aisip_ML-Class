    "### 📦 Plot 4: Box Plot — Under-5 Mortality by Income Group"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "fig, axes = plt.subplots(1, 2, figsize=(15, 6))\n",
    "\n",
    "income_order = ['Low Income', 'Lower-Middle', 'Upper-Middle', 'High Income']\n",
    "palette = {'Low Income':'#E53935', 'Lower-Middle':'#FB8C00',\n",
    "           'Upper-Middle':'#43A047', 'High Income':'#1E88E5'}\n",
    "\n",
    "# ── Left: Box plot ────────────────────────────────────────────────────────\n",
    "df_plot = df_clean[df_clean['income_group'].isin(income_order)]\n",
    "bp = axes[0].boxplot(\n",
    "    [df_plot[df_plot['income_group']==g]['under5_mortality'].dropna().values\n",
    "     for g in income_order if g in df_plot['income_group'].values],\n",
    "    labels=[g for g in income_order if g in df_plot['income_group'].values],\n",
    "    patch_artist=True, notch=False, medianprops={'color':'white','linewidth':2.5}\n",
    ")\n",
    "box_colors = [palette[g] for g in income_order if g in df_plot['income_group'].values]\n",
    "for patch, color in zip(bp['boxes'], box_colors):\n",
    "    patch.set_facecolor(color)\n",
    "    patch.set_alpha(0.8)\n",
    "\n",
    "# Overlay individual points\n",
    "for i, grp in enumerate([g for g in income_order if g in df_plot['income_group'].values]):\n",
    "    y = df_plot[df_plot['income_group']==grp]['under5_mortality'].dropna().values\n",
    "    x = np.random.normal(i+1, 0.06, size=len(y))\n",
    "    axes[0].scatter(x, y, alpha=0.6, color=box_colors[i], s=50, zorder=5, edgecolors='white')\n",
    "\n",
    "axes[0].set_ylabel('Under-5 Mortality (per 1,000 live births)', fontsize=11)\n",
    "axes[0].set_title('Under-5 Mortality by Income Group', fontsize=13, fontweight='bold')\n",
    "axes[0].tick_params(axis='x', rotation=15)\n",
    "axes[0].grid(axis='y', alpha=0.3)\n",
    "\n",
    "# ── Right: GDP by income group violin ─────────────────────────────────────\n",
    "valid_groups = [g for g in income_order if g in df_plot['income_group'].values]\n",
    "data_violin = [df_plot[df_plot['income_group']==g]['gdp_per_capita'].dropna().values\n",
    "               for g in valid_groups]\n",
    "\n",
    "vp = axes[1].violinplot(data_violin, positions=range(1, len(valid_groups)+1),\n",
    "                        showmedians=True, showextrema=True)\n",
    "for i, (body, color) in enumerate(zip(vp['bodies'], box_colors)):\n",
    "    body.set_facecolor(color)\n",
    "    body.set_alpha(0.7)\n",
    "\n",
    "axes[1].set_xticks(range(1, len(valid_groups)+1))\n",
    "axes[1].set_xticklabels(valid_groups, rotation=15, fontsize=10)\n",
    "axes[1].set_ylabel('GDP per Capita (USD)', fontsize=11)\n",
    "axes[1].set_title('GDP per Capita Distribution by Income Group', fontsize=13, fontweight='bold')\n",
    "axes[1].yaxis.set_major_formatter(mticker.FuncFormatter(lambda x, _: f'${x:,.0f}'))\n",
    "axes[1].grid(axis='y', alpha=0.3)\n",
    "\n",
    "fig.suptitle('📦 Box & Violin Plots — Health & Economy by Income Group',\n",
    "             fontsize=15, fontweight='bold', y=1.02)\n",
    "plt.tight_layout()\n",
    "plt.savefig('plot4_boxplot_mortality_income.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()"
